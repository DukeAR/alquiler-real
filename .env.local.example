# Frontend local development
# Copy to .env.local when running the Vite app locally.
# For a deployed frontend, set VITE_BACKEND_URL=https://tu-backend.onrender.com in .env.production or in the hosting provider.

# Leave empty to use the Vite proxy in development.
VITE_BACKEND_URL=

# Local backend target used only by the Vite dev proxy.
VITE_DEV_API_PROXY_TARGET=http://localhost:3001

# Optional client timeout in milliseconds.
VITE_API_TIMEOUT=30000