{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite\"",
    "dev:full": "node ./scripts/dev-full.cjs",
    "dev:frontend": "vite",
    "server": "cross-env NODE_ENV=development tsx server/index.ts",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "build": "vite build && npm run build:demo-audit",
    "build:analyze": "cross-env ANALYZE=true vite build && npm run build:demo-audit",
    "build:demo-audit": "tsx ./scripts/build-demo-audit.tsx",
    "preview": "vite preview --host 0.0.0.0",
    "clean": "rm -rf dist",
    "type-check": "npm run typecheck:app && npm run typecheck:server && npm run typecheck:tooling",
    "typecheck:app": "tsc --noEmit -p tsconfig.json",
    "typecheck:server": "tsc --noEmit -p tsconfig.server.json",
    "typecheck:tooling": "tsc --noEmit -p tsconfig.node.json",
    "lint": "npm run typecheck:app && npm run typecheck:server && npm run typecheck:tooling",
    "test": "cross-env NODE_ENV=test vitest"
  },
